# Redis
REDIS_URL=redis://redis:6379/0

# GPU / Inference
USE_GPU=true
CUDA_VISIBLE_DEVICES=0
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# File limits (matches FR-03: 20MB)
MAX_FILE_SIZE_MB=20
MAX_BATCH_SIZE=10

# Session storage (matches NFR-S02: 1hr auto-delete)
SESSION_TTL_SECONDS=3600
TEMP_STORAGE_PATH=/tmp/imagesr

# Model
MODEL_WEIGHTS_PATH=/app/models/003_realSR_BSRGAN_DFO_s64w8_SwinIR-M_x4_GAN.pth
DEFAULT_SCALE=4

# API rate limiting (matches NFR-S03: 60 req/min)
RATE_LIMIT_PER_MINUTE=60

# Environment
ENV=development